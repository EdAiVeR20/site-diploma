# Environment Variables
# Copy this file to .env and fill in your values

# Backend API URL
VITE_API_URL=http://localhost:3000/api

# Yandex Maps API Key
# Get your key from https://developer.tech.yandex.ru/
# IMPORTANT: In Yandex Developer Console, add your domain to HTTP Referer restrictions
VITE_YANDEX_MAPS_API_KEY=your_yandex_maps_api_key_here
